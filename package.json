{
  "name": "tinker-p4t",
  "version": "0.0.668",
  "description": "secret...",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "cc": "prettier --check './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "spell": "cspell './**/*.{js,jsx,ts,tsx}'",
    "build": "pnpm twx; pnpm format; tsc && vite build",
    "preview": "vite preview",
    "open": "open https://tinker-p4t.vercel.app"
  },
  "dependencies": {
    "preact": "10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.10.5",
    "@preact/signals": "2.9.4",
    "autoprefixer": "10.5.4",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "magic-string": "1.0.0",
    "only-allow": "1.2.2",
    "pettier": "1.1.0",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "proto-tailwindcss-clrs": "0.0.518",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
