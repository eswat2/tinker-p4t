{
  "name": "tinker-p4t",
  "version": "0.0.662",
  "description": "secret...",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "cc": "prettier --check './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "spell": "cspell './**/*.{js,jsx,ts,tsx}'",
    "build": "pnpm twx; pnpm format; tsc && vite build",
    "preview": "vite preview",
    "open": "open https://tinker-p4t.vercel.app"
  },
  "dependencies": {
    "preact": "10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.10.5",
    "@preact/signals": "2.9.3",
    "autoprefixer": "10.5.2",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "magic-string": "0.30.21",
    "only-allow": "1.2.2",
    "pettier": "1.1.0",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.513",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
