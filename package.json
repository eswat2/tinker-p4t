{
  "name": "tinker-p4t",
  "version": "0.0.644",
  "description": "secret...",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "cc": "prettier --check './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,jsx,ts,tsx}'",
    "spell": "cspell './**/*.{js,jsx,ts,tsx}'",
    "build": "pnpm twx; pnpm format; tsc && vite build",
    "preview": "vite preview",
    "open": "open https://tinker-p4t.vercel.app"
  },
  "dependencies": {
    "preact": "10.29.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.10.5",
    "@preact/signals": "2.9.2",
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "magic-string": "0.30.21",
    "only-allow": "1.2.2",
    "pettier": "1.1.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.505",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
